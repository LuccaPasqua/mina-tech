# =========================================================
#  Minatech — variáveis de ambiente (PROJETO ÚNICO)
# =========================================================
# Copie este arquivo para `.env` e preencha os valores.
#
# Há DOIS grupos de variáveis no mesmo arquivo:
#   1) SEM prefixo  -> lidas pelo SERVIDOR (Express). São SECRETAS.
#   2) Com VITE_     -> lidas pelo FRONT (Vite) e expostas no navegador.
#                       NUNCA coloque segredos em variáveis VITE_.
#
# Se as variáveis do Supabase ficarem em branco, o sistema sobe em
# MODO DEMO (dados em memória + login admin de demonstração).
#
# Na VERCEL: não suba o `.env`. Cadastre estas mesmas variáveis em
# Project Settings > Environment Variables.
# =========================================================

# ---------- SERVIDOR (secreto) ----------
# URL do projeto Supabase (ex.: https://xxxx.supabase.co)
SUPABASE_URL=

# Service role key (acesso total ao banco — NUNCA exponha no front)
SUPABASE_SERVICE_KEY=

# SUPER-ADMINS (separados por vírgula): permanentes e OCULTOS no painel —
# não aparecem na lista nem podem ser removidos pela interface. Ideal para o
# e-mail do dono/dev. Os demais admins são gerenciados PELO PRÓPRIO PAINEL
# (tabela `admin_emails` no Supabase). Se tudo ficar vazio, qualquer usuário
# autenticado é tratado como admin.
# Ex.: ADMIN_EMAILS=voce@gmail.com
ADMIN_EMAILS=

# Porta da API em desenvolvimento local.
PORT=3001

# Origem(ns) liberada(s) no CORS. Em projeto único (mesma origem) pode deixar *.
FRONTEND_URL=*

# ---------- FRONT (público, prefixo VITE_) ----------
# Mesmos dados do Supabase, mas a chave aqui é a ANON (pública).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
